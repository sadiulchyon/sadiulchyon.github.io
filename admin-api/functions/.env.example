# Copy this file to .env (same folder) and fill in real values. Never commit
# the real .env file.

# A fine-grained GitHub Personal Access Token, scoped to ONLY this repo
# (sadiulchyon/sadiulchyon.github.io) with "Contents: Read and write" permission.
# Create one at https://github.com/settings/personal-access-tokens/new
GITHUB_TOKEN=

# A password you make up yourself. Whoever knows this can edit the site's
# memories/photos, so make it long and random, not something guessable.
ADMIN_PASSWORD=
